# ==========================================================
# CHIKIN88 POS - Variables de entorno
# ==========================================================
# Copia este archivo como ".env" y rellena los valores reales.
#
# DÓNDE PONER CADA VARIABLE:
#   • Variables con prefijo VITE_  → embebidas en el bundle del navegador
#   • Variables SIN prefijo VITE_  → SOLO disponibles en /api/* (servidor)
#                                     NUNCA se exponen al navegador
#
# EN DESARROLLO LOCAL:
#   Pon TODAS estas variables en un archivo .env en la raíz del proyecto.
#
# EN VERCEL (producción):
#   Vercel → tu proyecto → Settings → Environment Variables
#   Pon TODAS estas variables ahí. Marca cada una para "Production",
#   "Preview" y "Development" según convenga (recomendado: las 3).

# ==========================================================
# FRONTEND (público, va al bundle del navegador)
# ==========================================================
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-anon-key-aqui

# ==========================================================
# SERVIDOR / SERVERLESS (privado, NUNCA expuesto al navegador)
# ==========================================================
# Usadas por /api/create-order y /api/daily-report.

# Mismo valor que VITE_SUPABASE_URL (Vercel necesita la copia sin prefijo)
SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Mismo valor que VITE_SUPABASE_ANON_KEY (para validar JWTs de usuarios)
SUPABASE_ANON_KEY=tu-anon-key-aqui

# Service role key (Supabase → Settings → API → service_role).
# ⚠️ CRÍTICO: NUNCA poner esto con prefijo VITE_. NUNCA en el navegador.
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui

# ==========================================================
# CRON / Email diario (opcional, solo si usas el reporte por email)
# ==========================================================
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REPORT_FROM_EMAIL=Chikin88 <reportes@tudominio.com>
REPORT_TO_EMAILS=correo1@tudominio.com,correo2@tudominio.com
CRON_SECRET=genera-un-string-largo-aleatorio-aqui

